<view class="container">
  <view class="card">
    <view class="section-title">我的提醒</view>
    <view wx:if="{{reminders.length > 0}}">
      <view wx:for="{{reminders}}" wx:key="_id" class="reminder-item">
        <view class="reminder-info">
          <view class="reminder-medicine">{{item.medicationName || item.medicineName}}</view>
          <view class="reminder-detail">{{item.repeatLabel}} {{item.time}}</view>
        </view>
        <view class="reminder-actions">
          <switch checked="{{item.enabled}}" bindchange="toggleReminder" data-id="{{item._id}}" />
          <button class="action-btn-small" bindtap="editReminder" data-id="{{item._id}}">编辑</button>
          <button class="action-btn-small delete" bindtap="deleteReminder" data-id="{{item._id}}">删除</button>
        </view>
      </view>
    </view>
    <view wx:else class="empty-state">
      <text class="empty-text">暂无提醒设置</text>
    </view>
  </view>

  <view class="add-btn-container">
    <button class="add-btn" bindtap="addReminder">
      <text class="add-icon">+</text>
      添加提醒
    </button>
  </view>
</view>
