<view class="page-container">
  <!-- 页面头部 -->
  <view class="page-header">
    <view class="header-content">
      <view class="header-title-section">
        <text class="header-icon">💊</text>
        <view class="header-text">
          <text class="header-title">我的药品</text>
          <text class="header-subtitle">共 {{medications.length}} 种药品</text>
        </view>
      </view>
      <view class="header-stats" wx:if="{{medications.length > 0}}">
        <view class="stat-chip {{stockLowCount > 0 ? 'warning' : 'normal'}}">
          <text class="stat-chip-text">{{stockLowCount > 0 ? stockLowCount + ' 种即将用完' : '库存充足'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 药品列表 -->
  <scroll-view scroll-y class="medication-list" enhanced show-scrollbar="{{false}}">
    <view wx:if="{{medications.length > 0}}" class="list-content">
      <view 
        wx:for="{{medications}}" 
        wx:key="_id" 
        class="medication-card {{index === 0 ? 'first' : ''}}"
        style="animation: slideInUp 0.3s ease-out {{index * 0.05}}s both;"
      >
        <!-- 卡片左侧：药品图标 -->
        <view class="card-left">
          <view class="medicine-icon-wrapper {{item.lowStock ? 'low-stock' : ''}}">
            <text class="medicine-icon">{{item.name[0] || '药'}}</text>
          </view>
          <view class="stock-indicator" wx:if="{{item.totalQuantity && item.remainingQuantity}}">
            <view class="stock-ring">
              <view class="stock-progress" style="height: {{((item.totalQuantity - item.remainingQuantity) / item.totalQuantity) * 100}}%;"></view>
            </view>
          </view>
        </view>

        <!-- 卡片中间：药品信息 -->
        <view class="card-center" bindtap="editMedication" data-id="{{item._id}}">
          <view class="info-main">
            <text class="medicine-name">{{item.name}}</text>
            <view class="info-tags">
              <text class="tag dosage-tag">{{item.dosage}}</text>
              <text class="tag frequency-tag">{{item.frequency}}</text>
              <text wx:if="{{item.instruction}}" class="tag instruction-tag">{{item.instruction}}</text>
            </view>
          </view>
          
          <view class="info-sub">
            <view class="stock-info-row" wx:if="{{item.totalQuantity}}">
              <text class="stock-label">剩余</text>
              <text class="stock-number {{stockLow(item) ? 'low' : ''}}">{{item.remainingQuantity || 0}}</text>
              <text class="stock-separator">/</text>
              <text class="stock-total">{{item.totalQuantity}}</text>
              <view class="stock-badge {{stockLow(item) ? 'badge-low' : 'badge-ok'}}">
                <text class="badge-text">{{stockLow(item) ? '库存不足' : '充足'}}</text>
              </view>
            </view>
            <view class="date-info" wx:if="{{item.startDate || item.endDate}}">
              <text class="date-text" wx:if="{{item.startDate}}">📅 {{item.startDate}}</text>
              <text class="date-separator" wx:if="{{item.startDate && item.endDate}}">至</text>
              <text class="date-text" wx:if="{{item.endDate}}">{{item.endDate}}</text>
            </view>
          </view>
        </view>

        <!-- 卡片右侧：快捷操作 -->
        <view class="card-right">
          <view class="action-btn edit-btn" bindtap="editMedication" data-id="{{item._id}}">
            <text class="action-icon">✏️</text>
          </view>
          <view class="action-btn delete-btn" catchtap="deleteMedication" data-id="{{item._id}}">
            <text class="action-icon">🗑️</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:else class="empty-state">
      <view class="empty-illustration">
        <text class="empty-icon-large">💊</text>
      </view>
      <text class="empty-title">暂无药品</text>
      <text class="empty-desc">点击下方按钮添加您的第一个药品</text>
      <view class="empty-action">
        <button class="empty-add-btn" bindtap="addMedication">
          <text class="btn-plus">+</text>
          <text class="btn-text">添加药品</text>
        </button>
      </view>
    </view>
  </scroll-view>

  <!-- 底部添加按钮 -->
  <view class="bottom-action-bar" wx:if="{{medications.length > 0}}">
    <button class="fab-button" bindtap="addMedication">
      <view class="fab-icon-wrap">
        <text class="fab-icon">+</text>
      </view>
      <text class="fab-text">添加药品</text>
    </button>
  </view>
</view>
