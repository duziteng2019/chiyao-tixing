/* ====================================
   首页样式 - 精简版
   设计风格：克制、留白、清晰的信息层次
   ==================================== */

.home-page {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: 40rpx;
}

/* ====== 头部区域 ====== */
.header-area {
  padding: 32rpx;
  padding-top: calc(32rpx + env(safe-area-inset-top));
}

.greeting-section {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.greeting {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  letter-spacing: 1rpx;
}

.date {
  font-size: 26rpx;
  color: #6B7280;
}

/* ====== 提醒区域 ====== */
.reminder-section {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.section-count {
  font-size: 24rpx;
  color: #9CA3AF;
  background: #F3F4F6;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

/* 提醒列表 */
.reminder-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.reminder-row {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.reminder-row:active {
  background: #F3F4F6;
}

.reminder-time-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin-right: 20rpx;
}

.reminder-time {
  font-size: 26rpx;
  font-weight: 600;
  color: #059669;
  min-width: 80rpx;
  text-align: center;
}

.time-indicator {
  width: 8rpx;
  height: 8rpx;
  background: #059669;
  border-radius: 50%;
}

.time-indicator.taken {
  background: #9CA3AF;
}

.reminder-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.reminder-medicine {
  font-size: 28rpx;
  font-weight: 500;
  color: #111827;
}

.reminder-dosage {
  font-size: 24rpx;
  color: #6B7280;
}

.reminder-action {
  margin-left: 16rpx;
}

.reminder-row.state-taken {
  opacity: 0.55;
}

.reminder-row.overdue {
  background: #FEF2F2;
  border-left: 4rpx solid #DC2626;
  border-radius: 12rpx;
}

/* 订阅引导卡片 */
.subscribe-reminder-card {
  margin: 24rpx 32rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  background: #EFF6FF;
  border-radius: 12rpx;
  border: 1rpx solid #BFDBFE;
}

.subscribe-reminder-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.subscribe-reminder-text {
  flex: 1;
}

.subscribe-reminder-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E40AF;
}

.subscribe-reminder-desc {
  font-size: 22rpx;
  color: #3B82F6;
}

.subscribe-reminder-arrow {
  font-size: 32rpx;
  color: #3B82F6;
}

.btn-mark {
  background: #059669;
  color: #FFFFFF;
  border-radius: 8rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: none;
}

.btn-mark:active {
  opacity: 0.9;
}

.status-taken {
  width: 48rpx;
  height: 48rpx;
  background: #ECFDF5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #059669;
}

/* 空状态 */
.empty-reminder {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* ====== 统计区域 ====== */
.stats-section {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 24rpx;
  background: #F9FAFB;
  border-radius: 12rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.2;
}

.stat-value.highlight {
  color: #059669;
}

.stat-label {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 6rpx;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #E5E7EB;
}

/* ====== 连续服药徽章 ====== */
.streak-badge {
  margin: 0 32rpx 32rpx;
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #F59E0B 0%, #F97316 100%);
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.streak-badge:active {
  transform: scale(0.98);
}

.streak-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.streak-info {
  flex: 1;
}

.streak-count {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
}

.streak-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.streak-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ====== 低库存警告 ====== */
.warning-section {
  margin: 0 32rpx 32rpx;
  padding: 20rpx;
  background: #FFFBEB;
  border-radius: 12rpx;
  border: 1rpx solid #FEF3C7;
}

.warning-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.warning-icon {
  font-size: 28rpx;
}

.warning-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #D97706;
}

.warning-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.warning-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 8rpx;
}

.warning-name {
  font-size: 26rpx;
  color: #111827;
}

.warning-remaining {
  font-size: 24rpx;
  color: #D97706;
}

/* ====== 快捷操作 ====== */
.action-section {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: #059669;
  border-radius: 12rpx;
  border: none;
  transition: all 0.2s ease;
}

.action-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.action-btn.secondary {
  background: #F3F4F6;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
  color: #FFFFFF;
}

.action-btn.secondary .action-icon {
  color: #059669;
}

.action-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.action-btn.secondary .action-text {
  color: #374151;
}

/* ====== 新手引导 ====== */
.guide-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.guide-content {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 40rpx;
  width: 100%;
  max-width: 520rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.guide-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.guide-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
}

.guide-desc {
  font-size: 26rpx;
  color: #6B7280;
  text-align: center;
  margin-bottom: 32rpx;
}

.guide-steps {
  width: 100%;
  margin-bottom: 32rpx;
}

.guide-step {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.guide-step:last-child {
  border-bottom: none;
}

.step-number {
  width: 40rpx;
  height: 40rpx;
  background: #059669;
  color: #FFFFFF;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-text {
  font-size: 26rpx;
  color: #374151;
}

.guide-btn {
  width: 100%;
  background: #059669;
  color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.guide-btn:active {
  opacity: 0.9;
}

/* ====== 动画 ====== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
