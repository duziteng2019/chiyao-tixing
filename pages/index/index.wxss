/* Loading Skeleton */
.loading-skeleton {
  padding: var(--space-md);
}

.skeleton-header,
.skeleton-card {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: var(--radius-2xl);
  margin-bottom: var(--space-md);
}

.skeleton-header {
  height: 180rpx;
}

.skeleton-card {
  height: 200rpx;
}

.skeleton-actions {
  display: flex;
  gap: var(--space-lg);
}

.skeleton-btn {
  flex: 1;
  height: 160rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: var(--radius-xl);
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* Header Card */
.header-card {
  background: var(--gradient-primary-long);
  border-radius: var(--radius-2xl);
  padding: 36rpx;
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-xl);
  position: relative;
  overflow: hidden;
}

.header-card::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.header-card::after {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

.greeting {
  font-size: var(--text-xl);
  font-weight: 700;
  color: var(--color-text-white);
  margin-bottom: var(--space-xs);
  position: relative;
  z-index: 1;
}

.date {
  font-size: var(--text-sm);
  color: rgba(255, 255, 255, 0.8);
  position: relative;
  z-index: 1;
}

/* Reminder Section */
.reminder-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-xs);
  background: var(--color-bg-card);
  border: 2rpx solid var(--color-border-light);
  transition: all 0.2s ease;
  box-sizing: border-box;
  width: 100%;
}

.reminder-item:active {
  transform: scale(0.98);
  border-color: var(--color-primary-border);
}

.reminder-time {
  font-size: var(--text-md);
  font-weight: 700;
  color: var(--color-primary);
  width: 120rpx;
  min-width: 120rpx;
  text-align: center;
  background: var(--color-primary-bg);
  padding: 12rpx 8rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  box-sizing: border-box;
}

.reminder-time-dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  background: var(--color-primary);
  border-radius: 50%;
  margin-right: 8rpx;
  animation: blink 2s ease-in-out infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.reminder-info {
  flex: 1;
  min-width: 0;
  margin-left: var(--space-md);
  overflow: hidden;
}

.medicine-name {
  font-size: var(--text-md);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}

.dosage {
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reminder-status {
  flex-shrink: 0;
  margin-left: var(--space-sm);
}

.status-taken {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: var(--color-primary);
  font-size: var(--text-sm);
  background: var(--color-primary-bg);
  padding: 8rpx 20rpx;
  border-radius: var(--radius-lg);
  font-weight: 600;
  white-space: nowrap;
}

.check-icon {
  width: 32rpx;
  height: 32rpx;
}

/* Stats Grid */
.stats-grid {
  display: flex;
  gap: var(--space-sm);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--gradient-primary-soft);
  padding: 28rpx 16rpx;
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--color-primary-border);
  box-sizing: border-box;
}

.stat-number {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 6rpx;
  line-height: 1.2;
}

.stat-label {
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
  font-weight: 500;
  white-space: nowrap;
}

/* Streak Banner */
.streak-banner {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #F59E0B 0%, #F97316 100%);
  border-radius: var(--radius-xl);
  padding: 28rpx 32rpx;
  margin-bottom: var(--space-md);
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.3);
}

.streak-icon-wrapper {
  flex-shrink: 0;
  margin-right: 20rpx;
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10px);
}

.streak-flame {
  font-size: 36rpx;
  animation: pulse-flame 1.5s ease-in-out infinite;
}

@keyframes pulse-flame {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.streak-info {
  flex: 1;
}

.streak-count {
  font-size: var(--text-base);
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  margin-bottom: 4rpx;
}

.streak-hint {
  font-size: var(--text-xs);
  color: rgba(255, 255, 255, 0.8);
}

.streak-arrow-wrapper {
  width: 48rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.streak-arrow {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1;
}

.streak-banner:active .streak-arrow-wrapper {
  transform: translateX(4rpx);
  background: rgba(255, 255, 255, 0.3);
}

/* Stock Warning Card */
.stock-warning-card {
  background: #FFFBEB !important;
  border: 2rpx solid var(--color-warning-border) !important;
  cursor: pointer;
}

.stock-warning-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-sm);
}

.stock-warning-icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  background: rgba(217, 119, 6, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.warning-symbol {
  font-size: 28rpx;
  line-height: 1;
}

.stock-warning-title {
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--color-warning);
}

.stock-warning-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.stock-warning-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.8);
  padding: 16rpx 20rpx;
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-warning-border);
  flex: 1;
  min-width: 200rpx;
}

.stock-warning-name {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-text-primary);
}

.stock-warning-remain {
  font-size: var(--text-xs);
  color: var(--color-warning);
  font-weight: 500;
  margin-left: auto;
}

/* Quick Actions */
.quick-actions {
  display: flex;
  gap: var(--space-lg);
  margin-top: var(--space-xs);
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 20rpx;
  background: var(--gradient-primary);
  border-radius: var(--radius-xl);
  border: none;
  box-shadow: var(--shadow-lg);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  color: var(--color-text-white);
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
}

.action-btn::after {
  border: none;
}

.action-btn:active {
  transform: scale(0.96) translateY(2rpx);
  box-shadow: var(--shadow-sm);
}

.action-btn-secondary {
  background: var(--gradient-accent);
}

.action-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-sm);
  backdrop-filter: blur(10px);
}

.action-icon-plus {
  font-size: 40rpx;
  font-weight: 300;
  line-height: 1;
}

.bell-icon {
  width: 32rpx;
  height: 32rpx;
  filter: brightness(0) invert(1);
}

/* Guide */
.guide-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.guide-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  width: 100%;
  max-width: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
  animation: slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.guide-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #059669 0%, #10B981 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(5, 150, 105, 0.35);
}

.guide-wave {
  font-size: 56rpx;
  line-height: 1;
}

.guide-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 16rpx;
}

.guide-desc {
  font-size: 28rpx;
  color: #6B7280;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 36rpx;
}

.guide-steps {
  width: 100%;
  margin-bottom: 36rpx;
}

.guide-step {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F3F4F6;
}

.guide-step:last-child {
  border-bottom: none;
}

.guide-step-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--gradient-primary);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  line-height: 48rpx;
  flex-shrink: 0;
}

.guide-step-text {
  font-size: 30rpx;
  color: #374151;
  font-weight: 500;
}

.guide-btn {
  width: 100%;
  background: var(--gradient-primary);
  color: #FFFFFF;
  border: none;
  border-radius: 24rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.guide-btn::after {
  border: none;
}

.guide-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.guide-btn-secondary {
  width: 100%;
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary-border);
  border-radius: 24rpx;
  padding: 28rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.guide-btn-secondary::after {
  border: none;
}

.guide-btn-secondary:active {
  background: var(--color-primary-bg);
}

.action-btn .action-btn-text {
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--color-text-white);
}
