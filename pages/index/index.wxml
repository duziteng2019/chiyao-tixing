<view class="container">
  <view wx:if="{{isLoading}}" class="loading-skeleton">
    <view class="skeleton-header"></view>
    <view class="skeleton-card"></view>
    <view class="skeleton-card"></view>
    <view class="skeleton-actions">
      <view class="skeleton-btn"></view>
      <view class="skeleton-btn"></view>
    </view>
  </view>

  <view wx:else>
  <view class="header-card">
    <view class="greeting">你好，{{userName}}</view>
    <view class="date">{{currentDate}}</view>
  </view>

  <view class="card">
    <view class="section-title">今日提醒</view>
    <view wx:if="{{todayReminders.length > 0}}">
      <view wx:for="{{todayReminders}}" wx:key="id" class="reminder-item">
        <view class="reminder-time">
          <text class="reminder-time-dot"></text>
          {{item.time}}
        </view>
        <view class="reminder-info">
          <view class="medicine-name">{{item.medicineName}}</view>
          <view class="dosage">{{item.dosage}}</view>
        </view>
        <view class="reminder-status">
          <button wx:if="{{!item.taken}}" class="btn-take" bindtap="markAsTaken" data-id="{{item.id}}">已服用</button>
          <text wx:else class="status-taken">已服</text>
        </view>
      </view>
    </view>
    <view wx:else class="empty-state">
      <text class="empty-text">今日暂无提醒</text>
    </view>
  </view>

  <view class="streak-banner" wx:if="{{stats.streak > 0}}" bindtap="goToMedication">
    <text class="streak-icon">🔥</text>
    <view class="streak-info">
      <text class="streak-count">连续服药 {{stats.streak}} 天</text>
      <text class="streak-hint">继续保持！</text>
    </view>
    <text class="streak-arrow">›</text>
  </view>

  <view class="card stock-warning-card" wx:if="{{lowStockMedications.length > 0}}" bindtap="goToMedication">
    <view class="stock-warning-header">
      <text class="stock-warning-icon">⚠️</text>
      <text class="stock-warning-title">{{lowStockMedications.length}} 种药品即将用完</text>
    </view>
    <view class="stock-warning-list">
      <view wx:for="{{lowStockMedications}}" wx:key="_id" class="stock-warning-item">
        <text class="stock-warning-name">{{item.name}}</text>
        <text class="stock-warning-remain">剩余 {{item.remainingQuantity}}/{{item.totalQuantity}}</text>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">服药统计</view>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-number">{{stats.todayCount}}</text>
        <text class="stat-label">今日应服</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.takenCount}}</text>
        <text class="stat-label">已服用</text>
      </view>
      <view class="stat-item">
        <text class="stat-number">{{stats.compliance}}%</text>
        <text class="stat-label">依从性</text>
      </view>
    </view>
  </view>

  <view class="quick-actions">
    <button class="action-btn" bindtap="goToAddMedication">
      <text class="action-icon">+</text>
      <text class="action-btn-text">添加药品</text>
    </button>
    <button class="action-btn action-btn-secondary" bindtap="goToAddReminder">
      <text class="action-icon">&</text>
      <text class="action-btn-text">设置提醒</text>
    </button>
  </view>
  </view>

  <!-- 新手引导 -->
  <view wx:if="{{showGuide}}" class="guide-overlay">
    <view class="guide-card">
      <view class="guide-icon">👋</view>
      <text class="guide-title">欢迎使用吃药提醒</text>
      <text class="guide-desc">轻松管理药品信息，设置服药提醒，追踪你的健康数据</text>
      <view class="guide-steps">
        <view class="guide-step">
          <text class="guide-step-num">1</text>
          <text class="guide-step-text">添加你的药品信息</text>
        </view>
        <view class="guide-step">
          <text class="guide-step-num">2</text>
          <text class="guide-step-text">为药品设置服药提醒</text>
        </view>
        <view class="guide-step">
          <text class="guide-step-num">3</text>
          <text class="guide-step-text">收到提醒，按时服药</text>
        </view>
      </view>
      <button class="guide-btn" bindtap="dismissGuide">开始使用</button>
      <button class="guide-btn-secondary" bindtap="goToAddMedication">先去添加药品</button>
    </view>
  </view>
</view>
