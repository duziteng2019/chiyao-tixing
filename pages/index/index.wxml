<view class="home-page">
  <!-- 头部区域 -->
  <view class="header-area">
    <view class="greeting-section">
      <text class="greeting">你好，{{userName}}</text>
      <text class="date">{{currentDate}}</text>
    </view>
  </view>

  <!-- 今日提醒区域 -->
  <view class="reminder-section">
    <view class="section-header">
      <text class="section-title">今日提醒</text>
      <text class="section-count">{{todayReminders.length}} 项</text>
    </view>

    <view wx:if="{{todayReminders.length > 0}}" class="reminder-list">
      <view
        wx:for="{{todayReminders}}"
        wx:key="id"
        class="reminder-row {{item.isOverdue && !item.taken ? 'overdue' : ''}} {{item.taken ? 'state-taken' : ''}}"
        style="animation: fadeInUp 0.3s ease-out {{index * 0.08}}s both;"
      >
        <view class="reminder-time-wrap">
          <text class="reminder-time">{{item.time}}</text>
          <view class="time-indicator {{item.taken ? 'taken' : ''}}"></view>
        </view>
        <view class="reminder-content">
          <text class="reminder-medicine">{{item.medicineName}}</text>
          <text class="reminder-dosage">{{item.dosage}}</text>
          <text wx:if="{{item.instruction}}" class="reminder-instruction">{{item.instruction}}</text>
        </view>
        <view class="reminder-action">
          <button 
            wx:if="{{!item.taken}}" 
            class="btn-mark" 
            bindtap="markAsTaken" 
            data-id="{{item.id}}"
          >已服</button>
          <view wx:else class="status-taken" bindtap="undoMarkAsTaken" data-id="{{item.id}}">✓</view>
        </view>
      </view>
    </view>

    <view wx:else class="empty-reminder">
      <text class="empty-icon">⏰</text>
      <text class="empty-text">今日暂无提醒</text>
      <text class="empty-hint">去添加药品并设置提醒吧</text>
    </view>
  </view>

  <!-- 统计区域 -->
  <view class="stats-section">
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-value">{{stats.todayCount}}</text>
        <text class="stat-label">今日应服</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{stats.takenCount}}</text>
        <text class="stat-label">已服用</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value highlight">{{stats.compliance}}%</text>
        <text class="stat-label">依从性</text>
      </view>
    </view>
  </view>

  <!-- 连续服药徽章 -->
  <view wx:if="{{stats.streak > 0}}" class="streak-badge" bindtap="goToMedication">
    <text class="streak-icon">🔥</text>
    <view class="streak-info">
      <text class="streak-count">连续服药 {{stats.streak}} 天</text>
      <text class="streak-hint">继续保持！</text>
    </view>
    <text class="streak-arrow">›</text>
  </view>

  <!-- 低库存警告 -->
  <view wx:if="{{lowStockMedications.length > 0}}" class="warning-section" bindtap="goToMedication">
    <view class="warning-header">
      <text class="warning-icon">⚠️</text>
      <text class="warning-title">{{lowStockMedications.length}} 种药品即将用完</text>
    </view>
    <view class="warning-list">
      <view wx:for="{{lowStockMedications}}" wx:key="_id" class="warning-item">
        <text class="warning-name">{{item.name}}</text>
        <text class="warning-remaining">剩余 {{item.remainingQuantity}} 份</text>
      </view>
    </view>
  </view>

  <!-- 订阅提醒引导卡片 -->
  <view wx:if="{{!isSubscribed && pendingCount > 0}}" class="subscribe-reminder-card" bindtap="requestSubscribeIfNeeded">
    <text class="subscribe-reminder-icon">🔔</text>
    <view class="subscribe-reminder-text">
      <text class="subscribe-reminder-title">开启服药提醒</text>
      <text class="subscribe-reminder-desc">不错过每一次服药时间</text>
    </view>
    <text class="subscribe-reminder-arrow">›</text>
  </view>

  <!-- 快捷操作 -->
  <view class="action-section">
    <button class="action-btn" bindtap="goToAddMedication">
      <text class="action-icon">+</text>
      <text class="action-text">添加药品</text>
    </button>
    <button class="action-btn secondary" bindtap="goToAddReminder">
      <text class="action-icon">⏰</text>
      <text class="action-text">设置提醒</text>
    </button>
  </view>

  <!-- 新手引导弹窗 -->
  <view wx:if="{{showGuide}}" class="guide-overlay" catchtap="dismissGuide">
    <view class="guide-content" catchtap="">
      <view class="guide-icon">👋</view>
      <text class="guide-title">欢迎使用吃药提醒</text>
      <text class="guide-desc">轻松管理药品信息，设置服药提醒</text>
      <view class="guide-steps">
        <view class="guide-step">
          <text class="step-number">1</text>
          <text class="step-text">添加药品信息</text>
        </view>
        <view class="guide-step">
          <text class="step-number">2</text>
          <text class="step-text">设置服药提醒</text>
        </view>
        <view class="guide-step">
          <text class="step-number">3</text>
          <text class="step-text">按时服药</text>
        </view>
      </view>
      <button class="guide-btn" bindtap="dismissGuide">开始使用</button>
    </view>
  </view>
</view>
