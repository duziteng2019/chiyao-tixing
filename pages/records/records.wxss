.stats-grid {
  display: flex;
  gap: var(--space-sm);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--gradient-primary-soft);
  padding: 28rpx var(--space-xs);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--color-primary-border);
}

.stat-number {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 6rpx;
}

.stat-label {
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
  font-weight: 500;
}

/* Chart */
.chart-tabs {
  display: flex;
  gap: var(--space-sm);
  margin-bottom: var(--space-lg);
}

.tab-item {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  padding: var(--space-xs) var(--space-md);
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-border);
  font-weight: 500;
  transition: all 0.2s ease;
}

.tab-item.active {
  color: var(--color-primary);
  border-color: var(--color-primary);
  background: var(--color-primary-bg);
}

.chart-canvas {
  width: 100%;
  height: 320rpx;
}

/* Records List */
.record-item {
  display: flex;
  align-items: center;
  padding: var(--space-md) 20rpx;
  border-radius: var(--radius-md);
  margin-bottom: var(--space-xs);
  background: var(--color-bg-card);
  border: 2rpx solid var(--color-border-light);
  transition: all 0.2s ease;
}

.record-item:active {
  background: #F9FAFB;
}

.record-date {
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  font-weight: 500;
  background: #F3F4F6;
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-sm);
  text-align: center;
  flex-shrink: 0;
  min-width: 100rpx;
}

.record-info {
  flex: 1;
  margin-left: var(--space-lg);
}

.record-medicine {
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.record-time {
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
}

.record-status {
  font-size: var(--text-xs);
  padding: var(--space-xs) 20rpx;
  border-radius: var(--radius-lg);
  font-weight: 600;
  flex-shrink: 0;
}

.record-status.taken {
  background: var(--color-primary-bg);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary-border);
}

.record-status.missed {
  background: var(--color-danger-bg);
  color: var(--color-danger);
  border: 2rpx solid var(--color-danger-border);
}

/* Records Header */
.records-header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-sm);
}

.catch-up-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--gradient-primary);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-lg);
  padding: 12rpx 24rpx;
  font-size: var(--text-sm);
  font-weight: 600;
  line-height: 1;
}

.catch-up-btn::after {
  border: none;
}

.catch-up-btn:active {
  opacity: 0.85;
  transform: scale(0.96);
}

.catch-up-icon {
  font-size: 32rpx;
  font-weight: 300;
}

/* 补录表单 */
.catch-up-form {
  background: var(--color-primary-bg);
  border-radius: var(--radius-lg);
  padding: var(--space-md);
  margin-bottom: var(--space-md);
  border: 2rpx solid var(--color-primary-border);
}

.catch-up-field {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-sm);
}

.catch-up-label {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-text-primary);
  width: 100rpx;
  flex-shrink: 0;
}

.catch-up-picker {
  flex: 1;
  padding: 16rpx 20rpx;
  background: #FFFFFF;
  border-radius: var(--radius-md);
  font-size: var(--text-sm);
  color: var(--color-text-primary);
  border: 2rpx solid var(--color-border);
  text-align: right;
}

.catch-up-save-btn {
  width: 100%;
  margin-top: var(--space-sm);
  background: var(--gradient-primary);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-lg);
  padding: 20rpx;
  font-size: var(--text-base);
  font-weight: 600;
}

.catch-up-save-btn::after {
  border: none;
}

.catch-up-save-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

/* Section Actions */
.section-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: -72rpx;
  margin-bottom: 16rpx;
}

.report-btn {
  background: var(--gradient-primary);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-lg);
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1;
}

.report-btn::after {
  border: none;
}

.report-btn:active {
  opacity: 0.85;
  transform: scale(0.96);
}

/* 周报弹窗 */
.report-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.report-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  width: 100%;
  max-width: 620rpx;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.report-header {
  background: linear-gradient(135deg, #059669 0%, #10B981 100%);
  padding: 40rpx 36rpx;
  border-radius: 32rpx 32rpx 0 0;
  position: relative;
  text-align: center;
}

.report-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #FFFFFF;
  display: block;
  margin-bottom: 8rpx;
}

.report-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.report-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 0;
  border: none;
}

.report-close::after {
  border: none;
}

.report-body {
  padding: 36rpx;
}

.report-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.report-metric {
  flex: 1;
  text-align: center;
  background: var(--color-primary-bg);
  border-radius: var(--radius-lg);
  padding: 24rpx 12rpx;
  border: 2rpx solid var(--color-primary-border);
}

.report-value {
  font-size: 40rpx;
  font-weight: 800;
  color: #059669;
  display: block;
  margin-bottom: 6rpx;
}

.report-value.good {
  color: #059669;
}

.report-label {
  font-size: 22rpx;
  color: #6B7280;
  font-weight: 500;
}

.report-section {
  margin-bottom: 28rpx;
}

.report-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
  display: block;
  margin-bottom: 16rpx;
}

.report-chart {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  height: 200rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #E5E7EB;
}

.report-bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  justify-content: flex-end;
}

.report-bar-value {
  font-size: 20rpx;
  color: #059669;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.report-bar {
  width: 100%;
  max-width: 48rpx;
  background: linear-gradient(to top, #059669, #34D399);
  border-radius: 8rpx 8rpx 0 0;
  min-height: 8rpx;
  transition: height 0.3s ease;
}

.report-bar-label {
  font-size: 22rpx;
  color: #6B7280;
  margin-top: 8rpx;
}

.report-highlight {
  display: flex;
  align-items: center;
  background: #FFFBEB;
  border: 2rpx solid #FDE68A;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  gap: 16rpx;
}

.highlight-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}

.highlight-info {
  flex: 1;
}

.highlight-title {
  font-size: 24rpx;
  color: #6B7280;
  display: block;
  margin-bottom: 4rpx;
}

.highlight-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.report-footer-text {
  text-align: center;
  font-size: 24rpx;
  color: #9CA3AF;
  padding-top: 8rpx;
}
