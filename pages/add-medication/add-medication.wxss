page {
  background-color: #F5F5F5;
}

.container {
  padding: 32rpx;
  min-height: 100vh;
  background: #F5F5F5;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  margin-bottom: 36rpx;
}

.form-item:last-of-type {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #059669;
}

.form-input {
  width: 100%;
  padding: 28rpx 24rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #111827;
  border: 2rpx solid #E5E7EB;
  transition: all 0.3s ease;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #10B981;
  background: #FFFFFF;
  box-shadow: 0 0 0 8rpx rgba(16, 185, 129, 0.1);
}

.form-input::placeholder {
  color: #9CA3AF;
}

.form-textarea {
  width: 100%;
  padding: 24rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #111827;
  border: 2rpx solid #E5E7EB;
  min-height: 180rpx;
  transition: all 0.3s ease;
  line-height: 1.6;
  box-sizing: border-box;
}

.form-textarea:focus {
  border-color: #10B981;
  background: #FFFFFF;
  box-shadow: 0 0 0 8rpx rgba(16, 185, 129, 0.1);
}

.form-textarea::placeholder {
  color: #9CA3AF;
}

.input-with-scan {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.scan-input {
  flex: 1;
}

.scan-btn {
  width: 88rpx;
  height: 88rpx;
  min-height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  margin: 0;
  background: var(--color-primary-bg);
  border: 2rpx solid var(--color-primary-border);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.scan-btn::after {
  border: none;
}

.scan-btn:active {
  opacity: 0.7;
  transform: scale(0.95);
}

.scan-btn-icon {
  font-size: 40rpx;
  line-height: 1;
}

.picker {
  padding: 28rpx 24rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #111827;
  border: 2rpx solid #E5E7EB;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker::after {
  content: '›';
  font-size: 40rpx;
  color: #9CA3AF;
}

.picker:active {
  border-color: #10B981;
  background: #FFFFFF;
}

.picker:empty::after {
  color: #9CA3AF;
}

.btn-container {
  display: flex;
  padding-top: 48rpx;
  padding-bottom: 40rpx;
}

.btn-cancel {
  flex: 1;
  background: #FFFFFF;
  color: #374151;
  border-radius: 48rpx;
  padding: 28rpx;
  font-size: 30rpx;
  border: 2rpx solid #E5E7EB;
  font-weight: 600;
  margin-right: 20rpx;
}

.btn-cancel::after {
  border: none;
}

.btn-cancel:active {
  background: #F9FAFB;
  border-color: #D1D5DB;
}

.btn-save {
  flex: 1;
  background: linear-gradient(135deg, #059669 0%, #10B981 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  padding: 28rpx;
  font-size: 30rpx;
  border: none;
  font-weight: 600;
  box-shadow: 0 8rpx 28rpx rgba(5, 150, 105, 0.3);
}

.btn-save::after {
  border: none;
}

.btn-save:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 14rpx rgba(5, 150, 105, 0.2);
}