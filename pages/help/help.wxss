.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 30rpx;
  padding-bottom: 120rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: #666;
}

.help-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.help-item {
  border-bottom: 2rpx solid #f5f5f5;
  transition: all 0.3s ease;
}

.help-item:last-child {
  border-bottom: none;
}

.help-item.expanded {
  background: #fafafa;
}

.help-header {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
}

.help-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #81C784 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.help-icon {
  font-size: 36rpx;
  line-height: 1;
}

.help-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.expand-icon {
  font-size: 36rpx;
  color: #999;
  transition: transform 0.3s ease;
  flex-shrink: 0;
  line-height: 1;
}

.expand-icon.rotated {
  transform: rotate(180deg);
}

.help-content {
  padding: 0 28rpx 32rpx 124rpx;
  animation: slideDown 0.3s ease;
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.help-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #666;
  white-space: pre-line;
}

.support-section {
  margin-top: 48rpx;
  padding: 0 20rpx;
}

.support-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.3);
}

.support-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.footer {
  text-align: center;
  margin-top: 60rpx;
  padding: 20rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
}
