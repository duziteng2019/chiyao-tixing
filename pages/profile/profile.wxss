page {
  background-color: var(--color-bg-page);
}

.profile-page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: var(--space-md);
  padding-bottom: 140rpx;
}

.card {
  background: var(--color-bg-card);
  border-radius: var(--card-radius);
  padding: var(--card-padding);
  margin-bottom: var(--card-spacing);
}

.profile-card {
  background: linear-gradient(135deg, #059669 0%, #10B981 50%, #34D399 100%);
  color: #fff;
}

/* ====== View mode ====== */
.user-info {
  display: flex;
  align-items: center;
}

.user-avatar-wrapper {
  width: 100rpx;
  height: 100rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.4);
  object-fit: cover;
}

.user-avatar-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder-icon {
  font-size: 44rpx;
  opacity: 0.7;
  line-height: 1;
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 6rpx;
}

.user-status {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.edit-btn {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 12rpx 28rpx;
  color: #fff;
  font-size: 26rpx;
  border: none;
  flex-shrink: 0;
}

.edit-btn::after {
  border: none;
}

.edit-btn:active {
  opacity: 0.7;
}

/* ====== Edit mode ====== */
.edit-layout {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.edit-avatar-section {
  margin-bottom: 24rpx;
}

.edit-avatar-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  min-width: 0;
  min-height: 0;
  line-height: 1;
  font-size: 0;
}

.edit-avatar-btn::after {
  display: none;
}

.edit-avatar-btn:active {
  opacity: 0.8;
}

.edit-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
}

.edit-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-camera-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.2);
  border: 3rpx solid #059669;
  font-size: 18rpx;
  line-height: 1;
  z-index: 1;
}

.edit-nick-input {
  width: 100%;
  max-width: 400rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #fff;
  text-align: center;
}

.edit-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
  width: 100%;
  max-width: 400rpx;
}

.edit-cancel-btn {
  flex: 1;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  padding: 20rpx;
  color: #fff;
  font-size: 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.edit-cancel-btn::after {
  border: none;
}

.edit-cancel-btn:active {
  opacity: 0.7;
}

.edit-save-btn {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx;
  color: #059669;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.edit-save-btn::after {
  border: none;
}

.edit-save-btn:active {
  opacity: 0.85;
}

/* ====== Stats ====== */
.stats-card {
  padding: 28rpx 32rpx;
}

.stats {
  display: flex;
  align-items: center;
}

.stat {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.stat-value.green {
  color: #059669;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.divider {
  width: 2rpx;
  height: 60rpx;
  background: #eee;
  margin: 0 20rpx;
}

/* ====== Achievements ====== */
.achievements-card {
  padding: 32rpx;
}

.achievements-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.achievements-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.achievements-streak {
  font-size: 28rpx;
  font-weight: 600;
  color: #F59E0B;
}

.achievements-grid {
  display: flex;
  gap: 16rpx;
}

.achievement-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 8rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.achievement-item.locked {
  opacity: 0.5;
}

.achievement-badge {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #E5E7EB;
  background: #F9FAFB;
  transition: all 0.3s ease;
}

.achievement-item.unlocked .achievement-badge {
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}

.achievement-icon {
  font-size: 36rpx;
  line-height: 1;
}

.achievement-icon.grayscale {
  filter: grayscale(1);
}

.achievement-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #111827;
}

.achievement-desc {
  font-size: 20rpx;
  color: #6B7280;
  text-align: center;
}

/* ====== Menu ====== */
.menu-card {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f9f9f9;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-content {
  flex: 1;
}

.menu-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  display: block;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

.menu-arrow {
  font-size: 40rpx;
  color: #ccc;
}

.menu-version {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  margin-right: 12rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-left: 8rpx;
}

.status-dot.online {
  background: #10B981;
}

.status-dot.offline {
  background: #EF4444;
}

.footer {
  text-align: center;
  padding: 48rpx 0 24rpx;
}

.footer-title {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}

.footer-sub {
  font-size: 24rpx;
  color: #999;
  display: block;
}
